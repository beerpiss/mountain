{
  "name": "mountain",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "The best Discord bot, tailored for HVOC Family.",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc",
    "build:changelog": "npx @discordx/changelog --root=src",
